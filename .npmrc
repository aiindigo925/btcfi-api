# NPM 4-Layer Supply Chain Defense (replicated from aiindigo policy 2026-05-13)
# Layer 1: 7-day package cooling period (blocks day-0 malicious releases)
# Note: min-release-age non-functional on npm 11.11.0 — enforced manually + via npq
min-release-age=7

# Layer 3: Lockfile protection
package-lock=true
save-exact=true
audit=true
fund=false
