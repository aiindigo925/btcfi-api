{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.aiindigo925/btcfi",
  "title": "BTCFi API",
  "description": "Bitcoin intelligence for AI agents. 27 tools covering blockchain data, AI-powered analytics, security analysis, Solv Protocol BTCFi, ZK proofs, and real-time streams — powered by x402 micropayments (no API keys).",
  "version": "3.0.1",
  "license": "MIT",
  "websiteUrl": "https://btcfi.aiindigo.com",
  "repository": {
    "url": "https://github.com/aiindigo925/btcfi-api",
    "source": "github"
  },
  "tags": [
    "bitcoin",
    "btcfi",
    "x402",
    "micropayments",
    "zk-proofs",
    "intelligence",
    "security",
    "ai-agents",
    "solv-protocol",
    "defi"
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@aiindigo/btcfi-mcp",
      "version": "3.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BTCFI_API_URL",
          "description": "API base URL (default: https://btcfi.aiindigo.com)",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "EVM_PRIVATE_KEY",
          "description": "EVM private key for Base USDC x402 micropayments",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "SVM_PRIVATE_KEY",
          "description": "Solana private key for NLx402 micropayments (zero facilitator fees)",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "PAYMENT_NETWORK",
          "description": "Payment network: 'base' (Coinbase) or 'solana' (NLx402, zero fees)",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://btcfi.aiindigo.com/api/mcp"
    }
  ]
}
